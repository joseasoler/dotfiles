# Environment variables shared between .zshrc and .xprofile.

# General environment variables.
export VISUAL='featherpad'
export EDITOR='nano'
export GIT_EDITOR='nano'

# i3-volume.
export NO_NOTIFY_COLOR=''

# Style
export QT_STYLE_OVERRIDE=kvantum # Force Qt to use kvantum for styles.

# Development environment variables.
export CPM_SOURCE_CACHE='~/data/cpm'
