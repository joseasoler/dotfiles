# i3blocks configuration file.

# Global properties
separator=true
separator_block_width=20

[pacman-updates]
command=~/.config/i3blocks/scripts/pacman_updates.py
interval=3600
markup=pango

[cpu_data]
command=~/.config/i3blocks/scripts/cpu_data.py
interval=15
markup=pango

[gpu_data]
command=~/.config/i3blocks/scripts/gpu_data.py
interval=15
markup=pango

[ram_usage]
command=~/.config/i3blocks/scripts/ram_usage.py
interval=15
markup=pango

[filesystem_data]
command=~/.config/i3blocks/scripts/filesystem_data.py
interval=60
markup=pango

[volume]
command=~/.config/i3blocks/scripts/volume.py
interval=once
signal=10
markup=pango

[clock]
command=~/.config/i3blocks/scripts/clock.py
interval=1
markup=pango

[tray_separator]
full_text=
interval=once
