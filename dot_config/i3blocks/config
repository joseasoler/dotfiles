# i3blocks configuration file.

# Global properties
separator=true
separator_block_width=30

[pacman-updates]
command=~/.config/i3blocks/scripts/pacman_updates.py
interval=3600
markup=pango

[resource_monitor]
# ToDo set to the Zen 3 temperature sensor when the 5.10 kernel is released.
command=~/.config/i3blocks/scripts/resource_monitor.py -c k10temp -r jc42 -d /@nvme /home/jose/data
interval=15
markup=pango

[volume]
command=~/.config/i3blocks/scripts/volume.py
interval=once
signal=10
markup=pango

[clock]
command=~/.config/i3blocks/scripts/clock.py
interval=1
markup=pango

[tray_separator]
full_text=
interval=once
